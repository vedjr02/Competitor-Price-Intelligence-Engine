NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Scraping fallbacks for Cloudflare-protected stores (Notino, etc.)
# Free tier available at https://jina.ai/reader
